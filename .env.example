# ============================================================================
#  Linux Server Generic Backup - Configuration
#  Copy this file to .env and adjust the values.
#  Lines starting with # are comments. Empty lines are ignored.
#
#  Priority (high -> low): system environment > .env > built-in defaults
# ============================================================================

# -- Service start/stop commands (REQUIRED) -----------------------------------
# Command executed to STOP the service before backup.
# Example: STOP_CMD="systemctl stop myapp"
STOP_CMD=

# Command executed to START the service after backup.
# Example: START_CMD="systemctl start myapp"
START_CMD=

# -- Backup paths (REQUIRED) --------------------------------------------------
# Source data directory to back up (relative or absolute path).
# Example: SRC_DIR="/opt/myapp/data"
SRC_DIR=

# Directory where backup archives are stored (auto-created if missing).
# Example: BACKUP_DIR="/var/backups/myapp"
BACKUP_DIR=

# -- Retention policy (OPTIONAL, default: 30) ---------------------------------
# Maximum number of backup archives AND log files to keep. Newest files beyond
# this count are removed after a successful backup.
MAX_BACKUPS=30

# -- Backup naming (OPTIONAL, default: APP) -----------------------------------
# Filename prefix shared by backup archives and log files.
# Archive: {PREFIX}_backup_{timestamp}.tar.gz
# Log    : {PREFIX}_backup_{timestamp}.log
BACKUP_PREFIX=APP

# -- Logging (OPTIONAL, default: ./logs/) -------------------------------------
# Directory for log files (auto-created if missing).
LOG_DIR=./logs/
